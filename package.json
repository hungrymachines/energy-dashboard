  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/node": "~20.0.0",
    "happy-dom": "^15.11.0",
    "openapi-typescript": "~7.13.0",
    "rollup": "^4.28.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vitest": "^1.6.0"
  }
}
