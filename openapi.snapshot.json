  "components": {
    "schemas": {
      "ApplianceCreate": {
        "properties": {
          "appliance_type": {
            "type": "string",
            "title": "Appliance Type"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "config": {
            "type": "object",
            "title": "Config",
            "default": {}
          }
        },
        "type": "object",
        "required": [
          "appliance_type",
          "name"
        ],
        "title": "ApplianceCreate"
      },
      "ApplianceReading": {
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "state": {
            "type": "string",
            "title": "State"
          },
          "value": {
            "type": "number",
            "title": "Value"
          },
          "power_watts": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Power Watts"
          },
          "metadata": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "timestamp",
          "state",
          "value"
        ],
        "title": "ApplianceReading"
      },
      "ApplianceUpdate": {
        "properties": {
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "config": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Config"
          }
        },
        "type": "object",
        "title": "ApplianceUpdate"
      },
      "CheckoutResponse": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "CheckoutResponse"
      },
      "CreateCheckoutRequest": {
        "properties": {
          "tier": {
            "type": "string",
            "title": "Tier"
          },
          "success_url": {
            "type": "string",
            "title": "Success Url"
          },
          "cancel_url": {
            "type": "string",
            "title": "Cancel Url"
          }
        },
        "type": "object",
        "required": [
          "tier",
          "success_url",
          "cancel_url"
        ],
        "title": "CreateCheckoutRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HvacScheduleBody": {
        "properties": {
          "intervals": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Intervals"
          },
          "high_temps": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "High Temps"
          },
          "low_temps": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Low Temps"
          },
          "temp_trajectory": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temp Trajectory"
          }
        },
        "type": "object",
        "required": [
          "intervals",
          "high_temps",
